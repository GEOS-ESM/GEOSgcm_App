
import math

from gcmpy.run_tools.history_file_ops import (
        read_history_rc,
        get_collection_list
        )

def determine_nodes(io_server: bool,
                    nx: int, ny: int,
                    cpus_per_node: int,
                    history_rc_file: str
                    ) -> tuple[int]:
    """
    Given the atmospheric processor decomposition (nx, ny),
    the number of availble processors per node (cpus_per_node),
    and the number of HISTORY collections, this function 
    determines the total number of nodes needed,
    the number of nodes for the IO server and the number
    of backend processors.

    Parameters
    ----------
    io_server : bool
       Flag to check if we using an IO server.
    nx : int
       Number of processors along longitudes.
    ny : int
       Number of processors along latitudes.
    cpus_per_node : int
       Number of cores per node.
    history_rc_file : str
       The path to the HISTORY.rc file.

    Returns
    -------
    tuple of integers containing:
       nodes: total number of nodes needed
       n_oserver_nodes: number of nodes in the IO server
       n_backend_pes: number of backend processors
    """

    model_npes = nx * ny

    # First we calculate the number of model nodes
    n_model_nodes = math.ceil(model_npes / cpus_per_node)

    # Calculate OSERVER nodes based on recommended algorithm
    if io_server:

        # Next the number of frontend PEs is 10% of the model PEs
        n_frontend_pes = math.ceil(model_npes * 0.1)

        # Now we roughly figure out the number of collections in the HISTORY.rc
        history_dict = read_history_rc(history_rc_file)
        n_hist_collections = len(get_collection_list(history_dict))

        # The total number of oserver PEs is frontend PEs plus number of history collections
        n_oserver_pes = n_frontend_pes + n_hist_collections

        # calculate the number of oserver nodes
        n_oserver_nodes = math.ceil(n_oserver_pes / cpus_per_node)

        # The number of backend PEs is the number of history collections divided by the number of oserver nodes
        n_backend_pes = math.ceil(n_hist_collections / n_oserver_nodes)

        # multigroup requires at least two backend pes
        if (n_backend_pes < 2):
            n_backend_pes = 2

        # Calculate the total number of nodes to request from batch
        nodes = n_model_nodes + n_oserver_nodes
        n_oserver_nodes = n_oserver_nodes
        n_backend_pes   = n_backend_pes

    else:
        nodes = n_model_nodes
        n_oserver_nodes = 0
        n_backend_pes   = 0

    return nodes, n_oserver_nodes, n_backend_pes
